# Cloudflare Pages cache headers
# Reference: https://developers.cloudflare.com/pages/configuration/headers/

# Static assets — cache aggressively. Filenames are stable (not hashed) but we
# can re-cache by re-uploading. For images, fonts and the like that almost
# never change, a long max-age + immutable means the browser never re-requests
# during a session.
/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# Next.js build output is content-hashed and safe to cache forever.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# HTML pages — short cache so updates ship quickly, but still benefit from
# Cloudflare's edge cache plus revalidation.
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate
